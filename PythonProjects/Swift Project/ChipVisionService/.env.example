# Copy to .env if you prefer env-file based config instead of editing
# docker-compose.yml directly. Not required for the default local setup.

# Path (inside the container) to the Firebase service-account JSON key.
# Download one from: Firebase Console -> Project Settings -> Service Accounts
# -> "Generate new private key", for project pokerchipapp-f7a84. Save it as
# ChipVisionService/secrets/firebase-service-account.json (gitignored).
GOOGLE_APPLICATION_CREDENTIALS=/secrets/firebase-service-account.json

# Only needed if you ever rename/move the Storage bucket.
FIREBASE_STORAGE_BUCKET=pokerchipapp-f7a84.firebasestorage.app
