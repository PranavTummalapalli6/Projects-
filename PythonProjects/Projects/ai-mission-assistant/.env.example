# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_mission_assistant?schema=public"

# ─── JWT Auth ───────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"

# ─── LLM Provider ───────────────────────────────────────────────────────────
# Supported: openai | anthropic
LLM_PROVIDER="openai"
LLM_API_KEY="sk-..."
LLM_MODEL="gpt-4o"

# ─── Embeddings ─────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER="openai"
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_DIMENSIONS=1536

# ─── n8n Webhook ────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL="http://localhost:5678/webhook/send-email"

# ─── Application ────────────────────────────────────────────────────────────
PORT=3001
APP_URL="http://localhost:3000"
API_URL="http://localhost:3001"
NODE_ENV="development"

# ─── File Upload ────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20
UPLOAD_DIR="./storage/uploads"
